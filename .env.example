# Environment variables referenced by the n8n workflows in this repo.
# Copy to .env in your n8n host and populate. Never commit a real .env.

# --- OpenAI ---
# Used by every workflow's LLM nodes and the Workflow 4 embedding node.
OPENAI_API_KEY=

# --- Twitter / X (OAuth2 per account) ---
# These are stored as n8n credentials, not env vars, but the bearer-token
# raw HTTP nodes in Workflow 4's mention-monitoring path read these:
TWITTER_BEARER_DRIPPY=
TWITTER_BEARER_DROOPY=

# --- LinkedIn (OAuth2) ---
# Stored as n8n credential — no env var. Org page ID is hardcoded
# in Workflow 1 and listed in docs/SETUP.md.

# --- Telegram (Workflow 3, currently dead path) ---
# Stored as n8n credential. Chat ID is in the workflow JSON.

# --- Supabase (Workflow 4) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (Workflow 4 dedup) ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Pinecone (Workflow 4 — referenced, integration aspirational) ---
PINECONE_API_KEY=
PINECONE_INDEX=microvest-ai-memory
PINECONE_NAMESPACE=personality-memories

# --- SerpAPI (Workflow 2 web search) ---
SERPAPI_KEY=

# --- Workflow 5 — Transform Labs Event Promo ---

# Azure OpenAI (Transform Labs subscription) for event-intel extractor + parsers
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Anthropic Claude Sonnet 4.5 — Email Strategist agent
ANTHROPIC_API_KEY=

# Notion (Transform Labs workspace) — Events DB + Content HQ approval workflow
NOTION_API_KEY=
NOTION_EVENTS_DB_ID=
NOTION_CONTENT_HQ_DB_ID=

# Constant Contact (OAuth2) — email service provider
CONSTANT_CONTACT_CLIENT_ID=
CONSTANT_CONTACT_CLIENT_SECRET=
CONSTANT_CONTACT_LIST_ID=

# Azure Blob Storage — event image hosting (blogheaderimages container)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=blogheaderimages

# Slack — ops notifications + error alerts (3 channels: marketing-emails, n8n-workflow-error, user DMs)
SLACK_BOT_TOKEN=
SLACK_MARKETING_CHANNEL=marketing-emails
SLACK_ERROR_CHANNEL=n8n-workflow-error
